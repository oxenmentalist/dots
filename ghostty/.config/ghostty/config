font-family = "Maple Mono NF"
font-family-italic = "Maple Mono NF"
font-family-bold-italic = "Maple Mono NF"
font-style = Medium
font-style-bold = ExtraBold
font-style-italic = Light
font-style-bold-italic = Regular
font-size = 16
font-thicken = 1

theme = Kanagawa Wave
cursor-style = block
font-feature = calt

window-padding-x = 8
window-padding-y = 8

background-opacity = 0.98

copy-on-select = true
shell-integration-features = ssh-env,ssh-terminfo
